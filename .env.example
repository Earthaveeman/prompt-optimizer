# LLM Provider: claude | modelscope | deepseek | nvidia
LLM_PROVIDER=claude

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ModelScope Configuration (OpenAI-compatible)
MODELSCOPE_API_KEY=sk-your-key-here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL=stepfun-ai/Step-3.7-Flash

# DeepSeek Configuration (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# NVIDIA NIM Configuration (OpenAI-compatible)
# Use MODELS for multiple models: "id1:Label 1,id2:Label 2"
# If MODELS is not set, falls back to single MODEL
NVIDIA_API_KEY=sk-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODELS=openai/gpt-oss-120b:GPT-OSS 120B,stepfun-ai/step-3.7-flash:Step 3.7 Flash
